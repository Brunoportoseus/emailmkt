o<\u002Fp>\n                    <p style=\"margin:0 0 6px 0;font-family:'Barlow Condensed',Helvetica,Arial,sans-serif;font-size:42px;line-height:1;color:#FFFFFF;font-weight:700;letter-spacing:-1px;\">20% de desconto<\u002Fp>\n                    <p style=\"margin:0;font-family:'Barlow',Helvetica,Arial,sans-serif;font-size:14px;line-height:1.5;color:#FDEBD0;\">em toda a Coleção Italiana · <strong style=\"color:#FFFFFF;\">válido até 15 de maio<\u002Fstrong><\u002Fp>\n                  <\u002Ftd>\n                <\u002Ftr>\n              <\u002Ftbody><\u002Ftable>\n            <\u002Ftd>\n          <\u002Ftr>\n\n          <!-- ═══ TÍTULO PRINCIPAL ═══ -->\n          <tr>\n            <td align=\"center\" class=\"mobile-pad\" style=\"padding:40px 48px 36px 48px;background-color:#FFFFFF;\">\n              <p class=\"superlabel\" style=\"margin:0 0 10px 0;font-family:'Barlow Condensed',Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:4px;color:#C07B3A;font-weight:700;text-transform:uppercase;\">Coleção Firenze · Obispa Design<\u002Fp>\n              <h1 id=\"email-h1\" class=\"h-hero\" style=\"margin:0 0 18px 0;font-family:'Barlow Condensed',Helvetica,Arial,sans-serif;font-size:34px;line-height:1.1;color:#1A1A1A;font-weight:700;letter-spacing:-0.3px;\">A Coleção Italiana chegou<br>na Casa do Marceneiro<\u002Fh1>\n              <p style=\"margin:0 auto;max-width:440px;font-family:'Barlow',Helvetica,Arial,sans-serif;font-size:15px;line-height:1.7;color:#5A5A5A;\">Cinco famílias de peças inspiradas no Renascimento italiano — puxadores, manilhões, maçanetas e cabides com acabamentos em cobre escovado, latão dourado e níquel.<\u002Fp>\n            <\u002Ftd>\n          <\u002Ftr>\n\n          <!-- Divisor -->\n          <tr>\n            <td style=\"padding:0 36px;background-color:#FFFFFF;\">\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tbody><tr><td style=\"height:1px;line-height:1px;fo