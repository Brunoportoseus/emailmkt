7B3A;text-decoration:underline;\">Descadastrar<\u002Fa>\n                &nbsp;·&nbsp;\n                <a href=\"https://cmarceneiro.wscommerce.com.br/\" style=\"color:#C07B3A;text-decoration:underline;\">Política de Privacidade<\u002Fa>\n              <\u002Fp>\n            <\u002Ftd>\n          <\u002Ftr>\n\n        <\u002Ftbody><\u002Ftable>\n      <\u002Ftd>\n    <\u002Ftr>\n  <\u002Ftbody><\u002Ftable>\n\n\n<!-- ═══ TWEAKS PANEL ═══ -->\n<script>\nconst TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{\n  \"paleta\": \"cobre\",\n  \"tipografia\": \"editorial\",\n  \"desconto\": true\n}/*EDITMODE-END*/;\n\n(function() {\n  // ── Paletas ──────────────────────────────────────────────\n  const paletas = {\n    cobre: {\n      bg:        '#F0EAE0',\n      accent:    '#C07B3A',\n      ctaBg:     '#1A1A1A',\n      faixaBg:   '#C07B3A',\n      sepBg:     '#F0EAE0',\n      headerBdr: '#E5DDD2',\n      label:     'Cobre'\n    },\n    escuro: {\n      bg:        '#1A1712',\n      accent:    '#D4953A',\n      ctaBg:     '#0D0C0A',\n      faixaBg:   '#8B5E1E',\n      sepBg:     '#2A2520',\n      headerBdr: '#3A3530',\n      label:     'Escuro'\n    },\n    mineral: {\n      bg:        '#ECEEF0',\n      accent:    '#5B7A8C',\n      ctaBg:     '#2C3E50',\n      faixaBg:   '#5B7A8C',\n      sepBg:     '#E0E4E8',\n      headerBdr: '#CDD3D8',\n      label:     'Mineral'\n    }\n  };\n\n  // ── Tipografias ───────────────────────────────────────────\n  const tipografias = {\n    condensado: {\n      h1Font:    \"'Barlow Condensed', Helvetica, Arial, sans-serif\",\n      bodyFont:  \"'Barlow', Helvetica, Arial, sans-serif\",\n      h1Size:    '34px',\n      h1Weight:  '700',\n      h1Space:   '-0.3px',\n      prodSize:  '22px',\n      label:     'Condensado'\n    },\n    classico: {\n      h1Font:    \"'Cormorant Garamond', Georgia, serif\",\n      bodyFont:  \"'Cormorant Garamond', Georgia, serif\",\n      h1Size:    '38px',\n      h1Weight:  '600',\n      h1Space:   '0.5px',\n      prodSize:  '24px',\n      label:     'Clássico'\n    },\n    editorial: {\n      h1Font:    \"'Playfair Display', Georgia, serif\",\n      bodyFont:  \"'Barlow', Helvetica, Arial, sans-serif\",\n      h1Size:    '32px',\n      h1Weight:  '700',\n      h1Space:   '1px',\n      prodSize:  '21px',\n      label:     'Editorial'\n    }\n  };\n\n  // ── Estado ────────────────────────────────────────────────\n  let state = Object.assign({}, TWEAK_DEFAULTS);\n  let panelVisible = false;\n\n  // ── Aplicar Paleta ────────────────────────────────────────\n  function applyPaleta(nome) {\n    const p = paletas[nome];\n    document.body.style.backgroundColor = p.bg;\n\n    // fundo externo\n    const outerTd = document.querySelector('table[role=\"presentation\"] > tbody > tr > td');\n    if (outerTd) outerTd.style.backgroundColor = p.bg;\n\n    // separadores entre produtos\n    document.querySelectorAll('td[style*=\"F0EAE0\"]').forEach(el => {\n      el.style.backgroundColor = p.sepBg;\n    });\n\n    // faixa accent (todas tds com bgColor cobre/accent)\n    const faixaTd = document.getElementById('faixa-promo');\n    if (faixaTd) faixaTd.style.backgroundColor = p.faixaBg;\n\n    // CTA block\n    const ctaTd = document.getElementById('cta-block');\n    if (ctaTd) ctaTd.style.backgroundColor = p.ctaBg;\n\n    // footer\n    const footerTd = document.getElementById('footer-block');\n    if (footerTd) footerTd.style.backgroundColor = p.ctaBg === '#0D0C0A' ? '#080705' : '#111111';\n\n    // botão CTA principal\n    const ctaBtn = document.getElementById('cta-btn');\n    if (ctaBtn) {\n      ctaBtn.style.backgroundColor = p.accent;\n      ctaBtn.querySelector('a').style.backgroundColor = p.accent;\n    }\n\n    // labels laranja (superlabels)\n    document.querySelectorAll('.superlabel').forEach(el => {\n      el.style.color = p.accent;\n    });\n\n    // títulos de produto\n    document.querySelectorAll('.prod-title').forEach(el => {\n      el.style.color = p.bg === '#1A1712' ? '#F5F0E8' : '#1A1A1A';\n    });\n\n    // body texto\n    document.querySelectorAll('.prod-body').forEach(el => {\n      el.style.color = p.bg === '#1A1712' ? '#B0A898' : '#5A5A5A';\n    });\n\n    // cards brancos de produto\n    document.querySelectorAll('.prod-card').forEach(el => {\n      el.style.backgroundColor = p.bg === '#1A1712' ? '#2A2520' : '#FFFFFF';\n    });\n\n    // header\n    const headerTd = document.getElementById('header-block');\n    if (headerTd) {\n      headerTd.style.backgroundColor = p.bg === '#1A1712' ? '#2A2520' : '#FFFFFF';\n      headerTd.style.borderBottomColor = p.headerBdr;\n    }\n  }\n\n  // ── Aplicar Tipografia ────────────────────────────────────\n  function applyTipografia(nome) {\n    const t = tipografias[nome];\n    const h1 = document.getElementById('email-h1');\n    if (h1) {\n      h1.style.fontFamily = t.h1Font;\n      h1.style.fontSize = t.h1Size;\n      h1.style.fontWeight = t.h1Weight;\n      h1.style.letterSpacing = t.h1Space;\n    }\n    document.querySelectorAll('.prod-title').forEach(el => {\n      el.style.fontFamily = t.h1Font;\n      el.style.fontSize = t.prodSize;\n    });\n    document.querySelectorAll('.prod-body').forEach(el => {\n      el.style.fontFamily = t.bodyFont;\n    });\n  }\n\n  // ── Aplicar Desconto ──────────────────────────────────────\n  function applyDesconto(visible) {\n    const faixa = document.getElementById('faixa-row');\n    if (faixa) faixa.style.display = visible ? '' : 'none';\n  }\n\n  // ── Aplicar tudo ─────────────────────────────────────────\n  function applyAll(s) {\n    applyPaleta(s.paleta);\n    applyTipografia(s.tipografia);\n    applyDesconto(s.desconto);\n  }\n\n  // ── Persistir ─────────────────────────────────────────────\n  function persist(edits) {\n    window.parent.postMessage({ type: '__edit_mode_set_keys', edits }, '*');\n  }\n\n  // ── Painel HTML ───────────────────────────────────────────\n  function createPanel() {\n    const panel = document.createElement('div');\n    panel.id = 'tweaks-panel';\n    panel.style.cssText = `\n      position:fixed; bottom:24px; right:24px; width:260px;\n      background:#1C1A17; color:#F0EAE0; border-radius:10px;\n      box-shadow:0 8px 40px rgba(0,0,0,0.5); font-family:'Barlow',sans-serif;\n      z-index:9999; display:none; overflow:hidden;\n    `;\n\n    panel.innerHTML = `\n      <div style=\"padding:14px 16px 12px;border-bottom:1px solid #333;display:flex;justify-content:space-between;align-items:center;\">\n        <span style=\"font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:2px;text-transform:uppercase;font-weight:700;color:#C07B3A;\">Tweaks<\u002Fspan>\n        <button id=\"tweaks-close\" style=\"background:none;border:none;color:#888;font-size:18px;cursor:pointer;line-height:1;padding:0;\">&times;<\u002Fbutton>\n      <\u002Fdiv>\n\n      <div style=\"padding:16px;\">\n\n        <!-- Paleta -->\n        <div style=\"margin-bottom:18px;\">\n          <p style=\"margin:0 0 8px 0;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:600;\">Paleta de Cor<\u002Fp>\n          <div style=\"display:flex;gap:8px;\" id=\"paleta-opts\">\n            ${Object.entries(paletas).map(([k, v]) => `\n              <button data-paleta=\"${k}\" style=\"\n                flex:1;padding:8px 4px;border-radius:6px;border:2px solid ${state.paleta===k?'#C07B3A':'#333'};\n                background:${k==='cobre'?'#C07B3A':k==='escuro'?'#2A2520':'#5B7A8C'};\n                color:#fff;font-size:10px;font-family:'Barlow',sans-serif;letter-spacing:1px;\n                text-transform:uppercase;cursor:pointer;font-weight:600;\n              \">${v.label}<\u002Fbutton>\n            `).join('')}\n          <\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- Tipografia -->\n        <div style=\"margin-bottom:18px;\">\n          <p style=\"margin:0 0 8px 0;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:600;\">Tipografia<\u002Fp>\n          <div style=\"display:flex;flex-direction:column;gap:6px;\" id=\"tipo-opts\">\n            ${Object.entries(tipografias).map(([k, v]) => `\n              <button data-tipo=\"${k}\" style=\"\n                padding:8px 12px;border-radius:6px;text-align:left;cursor:pointer;\n                border:2px solid ${state.tipografia===k?'#C07B3A':'#333'};\n                background:${state.tipografia===k?'#2A2218':'transparent'};\n                color:#F0EAE0;font-size:13px;font-family:${v.h1Font};\n                letter-spacing:${v.h1Space};font-weight:${v.h1Weight};\n              \">${v.label}<\u002Fbutton>\n            `).join('')}\n          <\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- Faixa de Desconto -->\n        <div>\n          <p style=\"margin:0 0 8px 0;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888;font-weight:600;\">Faixa de Desconto<\u002Fp>\n          <label style=\"display:flex;align-items:center;gap:10px;cursor:pointer;\">\n            <div id=\"toggle-track\" style=\"\n              width:40px;height:22px;border-radius:11px;\n              background:${state.desconto?'#C07B3A':'#444'};\n              position:relative;transition:background .2s;cursor:pointer;\n            \">\n              <div id=\"toggle-thumb\" style=\"\n                position:absolute;top:3px;left:${state.desconto?'19px':'3px'};\n                width:16px;height:16px;border-radius:50%;background:#fff;\n                transition:left .2s;\n              \"><\u002Fdiv>\n            <\u002Fdiv>\n            <span style=\"font-size:12px;color:#CCC;\" id=\"toggle-label\">${state.desconto?'Visível':'Oculta'}<\u002Fspan>\n          <\u002Flabel>\n        <\u002Fdiv>\n\n      <\u002Fdiv>\n    `;\n\n    document.body.appendChild(panel);\n\n    // Fechar\n    panel.querySelector('#tweaks-close').addEventListener('click', () => {\n      panelVisible = false;\n      panel.style.display = 'none';\n      window.parent.postMessage({ type: '__edit_mode_dismissed' }, '*');\n    });\n\n    // Paleta buttons\n    panel.querySelectorAll('[data-paleta]').forEach(btn => {\n      btn.addEventListener('click', () => {\n        state.paleta = btn.dataset.paleta;\n        panel.querySelectorAll('[data-paleta]').forEach(b => {\n          b.style.borderColor = b.dataset.paleta === state.paleta ? '#C07B3A' : '#333';\n        });\n        applyPaleta(state.paleta);\n        persist({ paleta: state.paleta });\n      });\n    });\n\n    // Tipo buttons\n    panel.querySelectorAll('[data-tipo]').forEach(btn => {\n      btn.addEventListener('click', () => {\n        state.tipografia = btn.dataset.tipo;\n        panel.querySelectorAll('[data-tipo]').forEach(b => {\n          b.style.borderColor = b.dataset.tipo === state.tipografia ? '#C07B3A' : '#333';\n          b.style.background  = b.dataset.tipo === state.tipografia ? '#2A2218' : 'transparent';\n        });\n        applyTipografia(state.tipografia);\n        persist({ tipografia: state.tipografia });\n      });\n    });\n\n    // Toggle desconto\n    const track = panel.querySelector('#toggle-track');\n    const thumb = panel.querySelector('#toggle-thumb');\n    const lbl   = panel.querySelector('#toggle-label');\n    track.addEventListener('click', () => {\n      state.desconto = !state.desconto;\n      track.style.background = state.desconto ? '#C07B3A' : '#444';\n      thumb.style.left = state.desconto ? '19px' : '3px';\n      lbl.textContent  = state.desconto ? 'Visível' : 'Oculta';\n      applyDesconto(state.desconto);\n      persist({ desconto: state.desconto });\n    });\n\n    return panel;\n  }\n\n  // ── Protocolo Host ────────────────────────────────────────\n  let panel;\n  window.addEventListener('message', e => {\n    if (e.data?.type === '__activate_edit_mode') {\n      if (!panel) panel = createPanel();\n      panel.style.display = 'block';\n      panelVisible = true;\n    }\n    if (e.data?.type === '__deactivate_edit_mode') {\n      if (panel) panel.style.display = 'none';\n      panelVisible = false;\n    }\n  });\n\n  window.parent.postMessage({ type: '__edit_mode_available' }, '*');\n  // re-anunciar caso o host ainda não estivesse pronto\n  setTimeout(() => window.parent.postMessage({ type: '__edit_mode_available' }, '*'), 300);\n  setTimeout(() => window.parent.postMessage({ type: '__edit_mode_available' }, '*'), 1000);\n\n  // ── Init ──────────────────────────────────────────────────\n  window.addEventListener('DOMContentLoaded', () => {\n    applyAll(state);\n  });\n  if (document.readyState !== 'loading') applyAll(state);\n\n})();\n<\u002Fscript>\n\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
